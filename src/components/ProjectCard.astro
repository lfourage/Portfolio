---
const { name, description, image, liveUrl, githubUrl, tags, index } =
  Astro.props;
const splashClass = `splash-${(index % 4) + 1}`;
---

<div
  class="card-container cursor-pointer"
  style="position: relative; width: min(380px, 90vw); aspect-ratio: 4/3; height: auto; min-height: 1px;"
>
  <div class="glow-wrapper absolute inset-0">
    <div class={`project-card-wrapper ${splashClass} absolute inset-0`}>
      <div
        class="relative w-full h-full overflow-hidden"
        style="background: var(--dark)"
      >
        <img
          src={image}
          alt={`Screenshot of ${name}`}
          class="card-img absolute inset-0 w-full h-full object-cover"
        />
        <div
          class="card-overlay absolute inset-0 flex flex-col items-center justify-center p-6 opacity-0 z-2"
        >
          <p
            class="font-belle text-center mb-4"
            style="color: var(--gold); font-size: clamp(0.8rem, 1.3vw, 1.1rem); text-shadow: 1px 1px 4px var(--dark)"
          >
            {description}
          </p>
          <div class="flex flex-wrap gap-3 justify-center">
            {
              liveUrl && (
                <a
                  href={liveUrl}
                  target="_blank"
                  class="card-link font-vcr"
                  style="font-size: clamp(0.7rem, 1vw, 0.85rem)"
                >
                  Live ↗
                </a>
              )
            }
            <a
              href={githubUrl}
              target="_blank"
              class="card-link font-vcr"
              style="font-size: clamp(0.7rem, 1vw, 0.85rem)">GitHub ↗</a
            >
          </div>
        </div>
        <div
          class="absolute bottom-0 left-0 right-0 p-2 z-3"
          style="background: linear-gradient(transparent, var(--dark-alpha))"
        >
          <p
            class="font-vcr mb-1"
            style="color: var(--gold); font-size: clamp(0.75rem, 1.2vw, 1rem); text-shadow: 1px 1px 4px var(--dark)"
          >
            {name}
          </p>
          <div class="flex flex-wrap gap-1">
            {tags.map((tag: string) => <span class="tag">{tag}</span>)}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .glow-wrapper {
    transition: filter 0.4s ease;
  }

  .card-container:hover .glow-wrapper {
    animation: glow-pulse 1.5s ease-in-out infinite;
  }

  .project-card-wrapper {
    width: 100%;
    height: 100%;
    transition:
      clip-path 0.4s ease,
      transform 0.4s ease;
  }

  .card-container:hover .project-card-wrapper {
    transform: scale(1.07);
  }

  .splash-1 {
    clip-path: polygon(8% 0%, 94% 2%, 100% 88%, 85% 100%, 5% 95%, 0% 12%);
  }
  .splash-2 {
    clip-path: polygon(
      5% 4%,
      90% 0%,
      98% 10%,
      95% 92%,
      12% 100%,
      0% 85%,
      2% 5%
    );
  }
  .splash-3 {
    clip-path: polygon(
      10% 0%,
      92% 3%,
      100% 15%,
      96% 90%,
      80% 100%,
      4% 96%,
      0% 8%
    );
  }
  .splash-4 {
    clip-path: polygon(
      3% 8%,
      88% 0%,
      100% 5%,
      97% 88%,
      90% 100%,
      8% 98%,
      0% 90%,
      2% 3%
    );
  }

  .card-container:hover .splash-1 {
    clip-path: polygon(5% 2%, 97% 0%, 98% 85%, 88% 100%, 2% 97%, 0% 8%);
  }
  .card-container:hover .splash-2 {
    clip-path: polygon(3% 2%, 93% 0%, 100% 8%, 97% 95%, 8% 100%, 0% 88%, 0% 3%);
  }
  .card-container:hover .splash-3 {
    clip-path: polygon(
      8% 2%,
      95% 0%,
      100% 12%,
      98% 93%,
      75% 100%,
      2% 98%,
      0% 5%
    );
  }
  .card-container:hover .splash-4 {
    clip-path: polygon(
      0% 5%,
      90% 0%,
      100% 3%,
      99% 90%,
      92% 100%,
      5% 100%,
      0% 93%,
      0% 0%
    );
  }

  .card-img {
    transition:
      transform 0.4s ease,
      filter 0.4s ease;
  }
  .card-container:hover .card-img {
    transform: scale(1.05);
    filter: brightness(0.35);
  }

  .card-overlay {
    transition: opacity 0.3s ease;
  }
  .card-container:hover .card-overlay {
    opacity: 1;
  }

  .card-link {
    padding: 4px 12px;
    border: 2px solid var(--gold);
    color: var(--gold);
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }
  .card-link:hover {
    background: var(--gold);
    color: var(--dark);
  }
</style>
