---
const { type, side } = Astro.props;
---

{
  type === "a" && (
    <div class={`building-group type-a ${side}`}>
      <div class="building-group-background">
        <div class="building bg">
          <div class="part">
            <div class="windows" />
          </div>
          <div class="ledge" />
          <div class="part">
            <div class="windows" />
          </div>
          <div class="ledge" />
          <div class="part">
            <div class="windows" />
          </div>
        </div>
      </div>
      <div class="building-group-foreground">
        <div class="building fg a">
          <div class="windows" />
        </div>
        <div class="building fg b">
          <div class="roof-top" />
          <div class="roof-bottom" />
          <div class="ledge" />
          <div class="part-mid">
            <div class="windows" />
          </div>
          <div class="ledge" />
          <div class="part-bottom">
            <div class="windows" />
          </div>
        </div>
        <div class="building fg c">
          <div class="windows" />
        </div>
        <div class="space" />
      </div>
    </div>
  )
}

{
  type === "b" && (
    <div class={`building-group type-b ${side}`}>
      <div class="building-group-background">
        <div class="building bg a">
          <div class="antena" />
          <div class="roof" />
          <div class="part">
            <div class="windows" />
          </div>
        </div>
        <div class="building bg b">
          <div class="roof" />
          <div class="ledge" />
          <div class="part">
            <div class="windows" />
          </div>
        </div>
      </div>
      <div class="building-group-foreground">
        <div class="building fg a">
          <div class="ledge" />
          <div class="part">
            <div class="windows" />
          </div>
          <div class="ledge" />
          <div class="part">
            <div class="windows" />
          </div>
        </div>
        <div class="building fg b">
          <div class="trapeze" />
          <div class="part-top">
            <div class="windows" />
          </div>
          <div class="part-mid">
            <div class="windows" />
          </div>
          <div class="part-bottom">
            <div class="windows" />
          </div>
        </div>
        <div class="building fg c">
          <div class="trapeze" />
          <div class="part">
            <div class="windows" />
          </div>
        </div>
        <div class="space" />
      </div>
    </div>
  )
}

{
  type === "c" && (
    <div class={`building-group type-c ${side}`}>
      <div class="building-group-background">
        <div class="building bg a">
          <div class="roof-top">
            <div class="windows" />
          </div>
          <div class="roof-bottom">
            <div class="windows" />
          </div>
          <div class="part">
            <div class="windows" />
          </div>
        </div>
        <div class="space" />
        <div class="building bg b">
          <div class="windows" />
        </div>
        <div class="building bg c">
          <div class="roof" />
          <div class="part">
            <div class="windows" />
          </div>
        </div>
      </div>
      <div class="building-group-foreground">
        <div class="building fg a">
          <div class="windows" />
        </div>
        <div class="building fg b">
          <div class="windows" />
        </div>
        <div class="building fg c">
          <div class="roof-top" />
          <div class="roof-bottom" />
          <div class="part">
            <div class="windows" />
          </div>
          <div class="ledge" />
          <div class="part">
            <div class="windows" />
          </div>
        </div>
      </div>
    </div>
  )
}

<style>
  .building-group {
    position: relative;
    width: 20vw;
    height: 100%;
    min-width: clamp(200px, 20vw, 403px);
  }

  .building-group-background {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .building-group-foreground {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .building {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .building-group-background .windows {
    width: 100%;
    height: 100%;
    background:
      repeating-linear-gradient(
        var(--violet-darker),
        var(--dark) 12px,
        transparent 12px,
        transparent 27px
      ),
      repeating-linear-gradient(
        90deg,
        var(--violet-darker),
        var(--dark) 19px,
        var(--pink) 19px,
        var(--gold) 29px
      );
    box-shadow: -2px 1px 15px var(--pink-alpha);
  }

  .building-group-foreground .windows {
    width: 100%;
    height: 100%;
    background:
      repeating-linear-gradient(
        var(--violet),
        var(--violet-darker) 5px,
        var(--violet-darker) 12px,
        transparent 12px,
        transparent 27px
      ),
      repeating-linear-gradient(
        90deg,
        var(--violet),
        var(--violet-darker) 12px,
        var(--violet-darker) 19px,
        var(--pink) 19px,
        var(--gold) 29px
      );
    box-shadow: -2px 1px 15px var(--pink-alpha);
  }

  .left .building-group-background .building > *:not(.windows) {
    background: linear-gradient(110deg, var(--violet-darker), var(--dark));
    box-shadow: -2px 1px 15px var(--pink-alpha);
  }
  .left .building-group-foreground .building > *:not(.windows) {
    background: linear-gradient(
      110deg,
      var(--violet),
      var(--violet-darker) 70%
    );
    box-shadow: -2px 1px 15px var(--pink-alpha);
  }
  .right .building-group-background .building > *:not(.windows) {
    background: linear-gradient(-110deg, var(--violet-darker), var(--dark));
    box-shadow: -2px 1px 15px var(--pink-alpha);
  }
  .right .building-group-foreground .building > *:not(.windows) {
    background: linear-gradient(
      -110deg,
      var(--violet),
      var(--violet-darker) 70%
    );
    box-shadow: -2px 1px 15px var(--pink-alpha);
  }

  .space {
    width: 5%;
  }
  .ledge {
    height: 5%;
    width: 100%;
  }

  /* Type A */
  .type-a .bg {
    height: 75%;
    width: 90%;
    position: relative;
    left: 12%;
  }
  .type-a .part {
    height: 30%;
    width: 97%;
  }
  .type-a .fg.a {
    height: 60%;
    width: 20%;
  }
  .type-a .fg.b {
    height: 100%;
    min-width: 30%;
  }
  .type-a .roof-top {
    width: 5%;
    height: 5%;
    position: relative;
    left: 30%;
  }
  .type-a .roof-bottom {
    width: 90%;
    height: 5%;
    transform: perspective(15px) rotateX(10deg);
  }
  .type-a .part-mid {
    width: 90%;
    height: 40%;
  }
  .type-a .part-bottom {
    width: 100%;
    height: 40%;
  }
  .type-a .fg.c {
    height: 50%;
    width: 25%;
  }

  /* Type B */
  .type-b .bg.a {
    height: 95%;
    min-width: 15%;
  }
  .type-b .antena {
    height: 8%;
    width: 5%;
  }
  .type-b .roof {
    height: 7%;
    width: 80%;
  }
  .type-b .a .part {
    height: 85%;
    width: 100%;
  }
  .type-b .b .part {
    height: 92%;
    width: 95%;
  }
  .type-b .bg.b {
    height: 70%;
    min-width: 35%;
  }
  .type-b .fg.a {
    height: 65%;
    min-width: 30%;
  }
  .type-b .fg.a .part {
    width: 90%;
  }
  .type-b .fg.b {
    height: 90%;
    min-width: 15%;
  }
  .type-b .fg.b .trapeze {
    height: 3%;
    width: 42%;
    transform: perspective(10px) rotateX(10deg);
  }
  .type-b .part-top {
    width: 50%;
    height: 20%;
  }
  .type-b .part-mid {
    width: 70%;
    height: 33%;
  }
  .type-b .part-bottom {
    width: 100%;
    height: 45%;
  }
  .type-b .fg.c {
    height: 35%;
    min-width: 35%;
  }
  .type-b .fg.c .trapeze {
    height: 10%;
    width: 90%;
    transform: perspective(10px) rotateX(10deg);
  }
  .type-b .fg.c .part {
    width: 100%;
    height: 90%;
  }

  /* Type C */
  .type-c .bg.a {
    height: 100%;
    width: 20%;
    position: relative;
    right: 15%;
  }
  .type-c .bg.a .roof-top {
    height: 10%;
    width: 60%;
  }
  .type-c .bg.a .roof-bottom {
    height: 10%;
    width: 85%;
  }
  .type-c .bg.a .part {
    height: 80%;
    width: 100%;
  }
  .type-c .bg.b {
    height: 60%;
    min-width: 38%;
  }
  .type-c .bg.c {
    height: 60%;
    width: 35%;
  }
  .type-c .bg.c .roof {
    border-left: 90px solid var(--violet-darker);
    border-top: 30px solid transparent;
    border-right: 53px solid transparent;
  }
  .type-c .bg.c .part {
    height: 87%;
    width: 100%;
  }
  .type-c .fg.a {
    height: 55%;
    min-width: 27%;
  }
  .type-c .fg.b {
    height: 37%;
    min-width: 33%;
  }
  .type-c .fg.c {
    height: 90%;
    min-width: 18%;
  }
  .type-c .fg.c .roof-top {
    height: 3%;
    width: 20%;
    position: relative;
    right: 20px;
  }
  .type-c .fg.c .roof-bottom {
    height: 2%;
    width: 100%;
  }
  .type-c .fg.c .part {
    height: 45%;
    width: 95%;
  }

  @media (max-width: 1200px) {
    .type-b.left {
      display: none;
    }
  }
  @media (max-width: 900px) {
    .type-c.left {
      display: none;
    }
  }
  @media (max-width: 750px) {
    .type-a.left {
      display: none;
    }
  }
</style>
